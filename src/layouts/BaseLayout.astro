---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** If true, nav links point to /chang-lab/#section instead of #section */
  offIndex?: boolean;
}

const {
  title = 'Chang Lab — University of Florida',
  description = 'Our lab explores the frontiers of particle physics and advanced computing.',
  offIndex = false,
} = Astro.props;

const base = import.meta.env.BASE_URL;   // "/chang-lab"
const prefix = offIndex ? `${base}/` : '';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <link rel="icon" type="image/x-icon" href={`${base}/favicon.ico`} />
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
</head>

<body class="text-slate-800">
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- Header (outside page-wrap so position:fixed works) -->
  <header class="fixed top-0 z-40 w-full max-w-full overflow-hidden glass border-b border-slate-200/70">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex h-16 items-center justify-between">
        <a href={`${base}/`} class="flex items-center gap-3 font-semibold text-slate-900">
          <img src={`${base}/Logo4.001.png`} alt="Lab logo" class="h-10 w-10 rounded-full object-cover" />
          <span>Chang Lab</span>
        </a>
        <nav class="hidden lg:flex items-center gap-2" aria-label="Primary navigation">
          <a href={`${prefix}#top`}           class="topnav-link px-3 py-2 rounded-lg text-slate-700 hover:bg-slate-100">Home</a>
          <a href={`${prefix}#about`}         class="topnav-link px-3 py-2 rounded-lg text-slate-700 hover:bg-slate-100">About</a>
          <a href={`${prefix}#lab-news`}      class="topnav-link px-3 py-2 rounded-lg text-slate-700 hover:bg-slate-100">News</a>
          <a href={`${prefix}#research`}      class="topnav-link px-3 py-2 rounded-lg text-slate-700 hover:bg-slate-100">Research</a>
          <a href={`${prefix}#media`}         class="topnav-link px-3 py-2 rounded-lg text-slate-700 hover:bg-slate-100">Media</a>
          <a href={`${prefix}#people`}        class="topnav-link px-3 py-2 rounded-lg text-slate-700 hover:bg-slate-100">People</a>
          <a href={`${prefix}#presentations`} class="topnav-link px-3 py-2 rounded-lg text-slate-700 hover:bg-slate-100">Talks</a>
          <a href={`${prefix}#publications`}  class="topnav-link px-3 py-2 rounded-lg text-slate-700 hover:bg-slate-100">Publications</a>
          <a href={`${prefix}#teaching`}      class="topnav-link px-3 py-2 rounded-lg text-slate-700 hover:bg-slate-100">Teaching</a>
          <a href={`${prefix}#contact`}       class="topnav-link px-3 py-2 rounded-lg text-slate-700 hover:bg-slate-100">Contact</a>
          <a href={`${base}/blog/`}           class="topnav-link px-3 py-2 rounded-lg text-slate-700 hover:bg-slate-100">Blog</a>
        </nav>
        <button id="menuBtn" class="lg:hidden inline-flex items-center justify-center rounded-xl border border-slate-300 px-3 py-2 text-sm" aria-expanded="false" aria-controls="mobileMenu">Menu</button>
      </div>
    </div>
    <!-- mobile -->
    <div id="mobileMenu" class="lg:hidden hidden border-t border-slate-200 bg-white">
      <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-2 grid grid-cols-2 gap-2" aria-label="Mobile navigation">
        <a class="py-2" href={`${prefix}#top`}>Home</a>
        <a class="py-2" href={`${prefix}#about`}>About</a>
        <a class="py-2" href={`${prefix}#lab-news`}>News</a>
        <a class="py-2" href={`${prefix}#research`}>Research</a>
        <a class="py-2" href={`${prefix}#media`}>Media</a>
        <a class="py-2" href={`${prefix}#people`}>People</a>
        <a class="py-2" href={`${prefix}#presentations`}>Talks</a>
        <a class="py-2" href={`${prefix}#publications`}>Publications</a>
        <a class="py-2" href={`${prefix}#teaching`}>Teaching</a>
        <a class="py-2 col-span-2" href={`${prefix}#contact`}>Contact</a>
        <a class="py-2 col-span-2" href={`${base}/blog/`}>Blog</a>
      </nav>
    </div>
  </header>

<div class="page-wrap">
  <main id="main-content">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="py-10 border-t border-slate-200 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-sm text-slate-600 flex flex-col md:flex-row items-center justify-between gap-4">
      <div>&copy; <span id="year"></span> Chang Lab &bull; Department of Physics &bull; University of Florida</div>
      <div class="flex items-center gap-3">
        <a class="hover:underline" href="https://www.ufl.edu/accessibility/" rel="noopener noreferrer" target="_blank">Accessibility<span class="sr-only"> (opens in new tab)</span></a>
        <span aria-hidden="true">&bull;</span>
        <a class="hover:underline" href="https://privacy.ufl.edu/privacy-policies-and-procedures/onlineinternet-privacy-statement/" rel="noopener noreferrer" target="_blank">Privacy<span class="sr-only"> (opens in new tab)</span></a>
        <span aria-hidden="true">&bull;</span>
        <a class="hover:underline" href="https://github.com/changlab-gfx" rel="noopener noreferrer" target="_blank">GitHub<span class="sr-only"> (opens in new tab)</span></a>
      </div>
    </div>
  </footer>

  <script is:inline>
    // Mobile menu toggle
    const menuBtn = document.getElementById('menuBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    menuBtn.addEventListener('click', () => {
      const isHidden = mobileMenu.classList.toggle('hidden');
      menuBtn.setAttribute('aria-expanded', String(!isHidden));
    });
    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !mobileMenu.classList.contains('hidden')) {
        mobileMenu.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
        menuBtn.focus();
      }
    });
    // Current year
    document.getElementById('year').textContent = new Date().getFullYear();
  </script>
</div>
</body>
</html>
