---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const base = import.meta.env.BASE_URL;
---
<BaseLayout title="Blog — Chang Lab" offIndex={true}>
  <main class="pt-28 pb-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 mb-2">Blog</h1>
      <p class="text-lg text-slate-500 mb-12">Thoughts, updates, and stories from the Chang Lab.</p>

      <div class="space-y-10" id="blog-posts">
        {posts.map((post) => {
          const formattedDate = post.data.date.toLocaleDateString('en-US', {
            year: 'numeric', month: 'long', day: 'numeric',
          });
          return (
            <article class="border-b border-slate-200 pb-10">
              <time class="text-sm text-slate-400" datetime={post.data.date.toISOString().slice(0, 10)}>
                {formattedDate}
              </time>
              <h2 class="text-2xl font-semibold text-slate-900 mt-1 mb-3">
                <a href={`${base}/blog/${post.slug}/`} class="hover:text-[var(--brand)] transition-colors">
                  {post.data.title}
                </a>
              </h2>
              {post.data.description && (
                <p class="text-slate-600 leading-relaxed">{post.data.description}</p>
              )}
            </article>
          );
        })}
      </div>
    </div>
  </main>
</BaseLayout>
