  <script is:inline>
      // 1) Add your images here
      const heroImages = [
          "https://news.fnal.gov/wp-content/uploads/2020/06/cms-detector-0808022_01-A4-at-144-dpi.jpg",
          "https://cms.cern/sites/default/files/2022-06/detector_stripe01-min_0_0.jpeg",
          "https://cms.cern/sites/default/files/field/image/CMS_photo_3_courtesy_of_CERN.jpg",
          "https://cds.cern.ch/images/CERN-CO-1008289-04/file?size=medium",
          "https://cms.cern/sites/default/files/inline-images/HLT-2.png",
          "https://cds.cern.ch/images/CERN-HI-0610046-01/file?size=medium",
          "https://home.cern/sites/default/files/2018-06/computer_centre_image_resized_for_web.jpg",
          "https://cds.cern.ch/images/CERN-PHOTO-202108-102-11/file?size=medium",
          "https://cds.cern.ch/images/CERN-PHOTO-202108-102-1/file?size=medium",
          "https://cds.cern.ch/images/CERN-PHOTO-201901-009-1/file?size=medium",
      ];
      const heroAlts = [
          "The CMS detector at the CERN Large Hadron Collider",
          "Interior view of the CMS detector layers",
          "Technicians working on the CMS detector at CERN",
          "Aerial view of the CERN laboratory campus",
          "CMS high-level trigger system visualization",
          "Particle collision event display at CERN",
          "CERN computing center with rows of servers",
          "Scientists collaborating in the CERN control room",
          "Wide view of the CERN accelerator complex",
          "Panoramic view of the CERN research facility",
      ];

// 2) Elements
const surface = document.getElementById("heroSlides");
const prevBtn = document.getElementById("heroPrev");
const nextBtn = document.getElementById("heroNext");
const dotsWrap = document.getElementById("heroDots");
const carousel = document.getElementById("hero-carousel");
const pauseBtn = document.getElementById("heroPause");
const pauseIcon = document.getElementById("pauseIcon");
const playIcon = document.getElementById("playIcon");

// 3) Shuffle and start at a random slide (keep alt text in sync)
const indices = heroImages.map((_, i) => i).sort(() => Math.random() - 0.5);
const shuffled = indices.map(i => heroImages[i]);
const shuffledAlts = indices.map(i => heroAlts[i]);
let current = Math.floor(Math.random() * shuffled.length);
let slides = [];
let dots = [];

// 4) Build slides & dots
shuffled.forEach((src, i) => {
    const img = document.createElement("img");
    img.src = src;
    img.alt = shuffledAlts[i];
    img.className = "absolute inset-0 h-full w-full object-cover transition-opacity duration-700 opacity-0";
    img.decoding = "async";
    img.loading = i === current ? "eager" : "lazy";
    surface.appendChild(img);
    slides.push(img);

    const dot = document.createElement("button");
    dot.className = "h-6 w-6 flex items-center justify-center rounded-full group";
    const dotInner = document.createElement("span");
    dotInner.className = "h-2.5 w-2.5 rounded-full bg-white/50 group-hover:bg-white ring-1 ring-white/50";
    dot.appendChild(dotInner);
    dot.setAttribute("aria-label", "Go to slide " + (i + 1));
    dot.addEventListener("click", () => goTo(i, true));
    dotsWrap.appendChild(dot);
    dots.push(dot);
});

function render() {
    slides.forEach((el, i) => {
        el.style.opacity = i === current ? "1" : "0";
    });
    dots.forEach((d, i) => {
        const inner = d.querySelector('span');
        inner.className = "h-2.5 w-2.5 rounded-full ring-1 ring-white/50 " +
            (i === current ? "bg-white" : "bg-white/50 group-hover:bg-white");
        if (i === current) {
            d.setAttribute("aria-current", "true");
        } else {
            d.removeAttribute("aria-current");
        }
    });
}

function next(auto=false){ current = (current + 1) % slides.length; render(); if(!auto) resetTimer(); }
function prev(){ current = (current - 1 + slides.length) % slides.length; render(); resetTimer(); }
function goTo(i, manual=false){ current = i; render(); if(manual) resetTimer(); }

// 5) Controls
nextBtn.addEventListener("click", () => next());
prevBtn.addEventListener("click", () => prev());

// 6) Auto-advance (pause on hover/focus)
let timer = null;
let paused = false;
const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

function startTimer(){ if (!paused && !prefersReducedMotion) { timer = setInterval(() => next(true), 5000); } }
function stopTimer(){ clearInterval(timer); timer = null; }
function resetTimer(){ stopTimer(); startTimer(); }

carousel.addEventListener("mouseenter", stopTimer);
carousel.addEventListener("mouseleave", () => { if (!paused) startTimer(); });
carousel.addEventListener("focusin", stopTimer);
carousel.addEventListener("focusout", () => { if (!paused) startTimer(); });

// Pause/play toggle
pauseBtn.addEventListener("click", () => {
    paused = !paused;
    if (paused) {
        stopTimer();
        pauseBtn.setAttribute("aria-label", "Play carousel");
        pauseBtn.setAttribute("aria-pressed", "true");
        pauseIcon.classList.add("hidden");
        playIcon.classList.remove("hidden");
    } else {
        startTimer();
        pauseBtn.setAttribute("aria-label", "Pause carousel");
        pauseBtn.setAttribute("aria-pressed", "false");
        pauseIcon.classList.remove("hidden");
        playIcon.classList.add("hidden");
    }
});

// 7) Init
render();
startTimer();
  </script>


  <!-- About -->
  <section id="about" class="scroll-mt-28 py-16" aria-labelledby="about-heading">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="grid lg:grid-cols-12 gap-10 items-start">

              <!-- LEFT: Image carousel -->
              <div class="lg:col-span-6 order-1">
                  <div id="about-carousel" class="relative rounded-3xl overflow-hidden border border-slate-200 shadow-sm" role="region" aria-roledescription="carousel" aria-label="Lab photos">
                      <div id="aboutSlides" class="relative aspect-[16/9] bg-slate-200 overflow-hidden"></div>
                      <!-- Prev -->
                      <button id="aboutPrev" class="group absolute left-2 top-1/2 -translate-y-1/2 p-1" aria-label="Previous photo">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white/60 group-hover:text-white transition-colors drop-shadow" viewBox="0 0 20 20" fill="currentColor">
                              <path fill-rule="evenodd" d="M12.78 15.22a.75.75 0 01-1.06 0l-4.5-4.5a.75.75 0 010-1.06l4.5-4.5a.75.75 0 111.06 1.06L8.56 10l4.22 4.22a.75.75 0 010 1.06z" clip-rule="evenodd"/>
                          </svg>
                      </button>
                      <!-- Next -->
                      <button id="aboutNext" class="group absolute right-2 top-1/2 -translate-y-1/2 p-1" aria-label="Next photo">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white/60 group-hover:text-white transition-colors drop-shadow" viewBox="0 0 20 20" fill="currentColor">
                              <path fill-rule="evenodd" d="M7.22 4.78a.75.75 0 011.06 0l4.5 4.5a.75.75 0 010 1.06l-4.5 4.5a.75.75 0 11-1.06-1.06L11.44 10 7.22 5.78a.75.75 0 010-1.06z" clip-rule="evenodd"/>
                          </svg>
                      </button>
                      <!-- Dots -->
                      <div id="aboutDots" class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1"></div>
                  </div>
              </div>

              <!-- RIGHT: Text -->
              <div class="lg:col-span-6 order-2">
                  <h2 id="about-heading" class="text-2xl font-bold">About the Lab</h2>
                  <p class="mt-4 leading-relaxed">
                  Our lab explores the frontiers of particle physics and advanced computing at the CMS experiment of CERN's
                  <abbr title="Large Hadron Collider">LHC</abbr>. We analyze rare processes involving the W, Z, and Higgs boson, namely the
                  <em>electroweak</em> sectors, to test the Standard Model and search for <span class="font-semibold">new physics</span>.
                  In parallel, we develop <span class="font-semibold">GPU-accelerated</span> software and scalable workflows that make
                  high-throughput analysis fast and accessible.
                  </p>
                  <p class="mt-4 leading-relaxed">
                  We value open science, mentorship, and collaboration—students and postdocs lead projects that blend analysis,
                  methods, and computing to push discovery forward.
                  </p>
              </div>

          </div>
      </div>
  </section>

  <script is:inline>
  (function() {
    const aboutImages = [
      { src: "photos/group_pic_sep2025.jpg", alt: "Chang Lab group photo, September 2025" },
      { src: "photos/group_pic_summer2024.jpg", alt: "Chang Lab group photo, Summer 2024" },
      { src: "EventDisplay5lepLabel.jpg", alt: "WZZ five-lepton event display" },
    ];
    const surface = document.getElementById("aboutSlides");
    const dotsWrap = document.getElementById("aboutDots");
    let current = 0, slides = [], dots = [];

    aboutImages.forEach((item, i) => {
      const img = document.createElement("img");
      img.src = item.src;
      img.alt = item.alt;
      img.className = "absolute inset-0 h-full w-full object-cover transition-opacity duration-700 opacity-0";
      img.decoding = "async";
      img.loading = i === 0 ? "eager" : "lazy";
      surface.appendChild(img);
      slides.push(img);

      const dot = document.createElement("button");
      dot.className = "h-6 w-6 flex items-center justify-center rounded-full group";
      dot.setAttribute("aria-label", "Go to photo " + (i + 1));
      const inner = document.createElement("span");
      inner.className = "h-2.5 w-2.5 rounded-full bg-white/50 group-hover:bg-white ring-1 ring-white/50";
      dot.appendChild(inner);
      dot.addEventListener("click", () => { current = i; render(); resetTimer(); });
      dotsWrap.appendChild(dot);
      dots.push(dot);
    });

    function render() {
      slides.forEach((el, i) => { el.style.opacity = i === current ? "1" : "0"; });
      dots.forEach((d, i) => {
        const inner = d.querySelector("span");
        inner.className = "h-2.5 w-2.5 rounded-full ring-1 ring-white/50 " +
          (i === current ? "bg-white" : "bg-white/50 group-hover:bg-white");
        if (i === current) d.setAttribute("aria-current", "true");
        else d.removeAttribute("aria-current");
      });
    }

    document.getElementById("aboutNext").addEventListener("click", () => { current = (current + 1) % slides.length; render(); resetTimer(); });
    document.getElementById("aboutPrev").addEventListener("click", () => { current = (current - 1 + slides.length) % slides.length; render(); resetTimer(); });

    let timer = null;
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    function startTimer() { if (!reducedMotion) timer = setInterval(() => { current = (current + 1) % slides.length; render(); }, 6000); }
    function stopTimer() { clearInterval(timer); timer = null; }
    function resetTimer() { stopTimer(); startTimer(); }

    const carousel = document.getElementById("about-carousel");
    carousel.addEventListener("mouseenter", stopTimer);
    carousel.addEventListener("mouseleave", startTimer);
    carousel.addEventListener("focusin", stopTimer);
    carousel.addEventListener("focusout", startTimer);

    render();
    startTimer();
  })();
  </script>


