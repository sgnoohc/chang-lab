<script is:inline>
  // --- ScrollSpy: highlight nav item for section nearest the viewport center ---
  document.addEventListener('DOMContentLoaded', () => {
    const links = Array.from(document.querySelectorAll('nav .topnav-link[href^="#"]'));
    const idToLink = new Map(links.map(a => [a.getAttribute('href').slice(1), a]));

    // Only spy on sections that actually have nav links
    const sections = Array.from(document.querySelectorAll('section[id]'))
      .filter(sec => idToLink.has(sec.id));

    // Optional: if you have a fixed header, account for its height here (px)
    const HEADER_OFFSET = 0; // e.g. 72 for a 72px fixed header

    // Where is our "focus line"? 0.5 = exact middle of viewport
    const FOCUS_LINE = 0.5;

    // Highlight styles
    function setActive(id) {
      idToLink.forEach((link, key) => {
        const active = key === id;
        link.classList.toggle('bg-[var(--brand)]/10', active);
        link.classList.toggle('text-[var(--brand)]', active);
        link.classList.toggle('underline', active);
        link.classList.toggle('underline-offset-8', active);
        link.classList.toggle('decoration-[var(--accent)]', active);
        if (active) { link.setAttribute('aria-current', 'page'); } else { link.removeAttribute('aria-current'); }
      });
    }

    // Compute which section's midpoint is closest to the focus line
    let ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const vh = window.innerHeight;
        const focusY = HEADER_OFFSET + vh * FOCUS_LINE;
        let bestId = null;
        let bestDist = Infinity;

        for (const sec of sections) {
          const r = sec.getBoundingClientRect();
          const mid = r.top + r.height / 2;      // section midpoint (in viewport coords)
          const dist = Math.abs(mid - focusY);   // distance to our focus line
          // Only consider sections that have some presence on screen
          const visible = r.bottom > 0 && r.top < vh;
          if (visible && dist < bestDist) {
            bestDist = dist;
            bestId = sec.id;
          }
        }
        if (bestId) setActive(bestId);
        ticking = false;
      });
    }

    // Init + listeners
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
    onScroll(); // run once on load

    // Optional: immediate highlight on nav click
    links.forEach(a => a.addEventListener('click', () => {
      const id = a.getAttribute('href').slice(1);
      if (id) setActive(id);
    }));
  });
</script>


<script is:inline>
(function(){
  const hot1 = document.getElementById('hot1');
  const hot2 = document.getElementById('hot2');
  const secretBtn = document.getElementById('secretBtn');

  // ---- COPY your three constants exactly as in your page ----
  const SALT_B64 = window.SALT_B64 || "LqEg+sbP7ZRE/AHQ3N66jw==";
  const IV_B64   = window.IV_B64   || "ta21os7HIhehOTDS";
  const CT_B64   = window.CT_B64   || "RdDMcQ2/+aaqYxp09yFuY94pmcVpOO40O9x2Y0Wt0BzdPflK5mkcrm06nFho+kmN1yhXKE+z9j8y5iBq67idLxlTrbxgx6uKL1sYPEzw69cA2DDjR/gp38Ge4hnZaF8auvZDjA==";
  // -----------------------------------------------------------

  let stage = 0;       // 0: wait for first click, 1: wait for second
  let timer = null;
  const ms = parseInt(getComputedStyle(document.documentElement)
              .getPropertyValue('--reveal-window-ms')) || 6000;

  function reset(){
    stage = 0;
    if (timer) { clearTimeout(timer); timer = null; }
    secretBtn.classList.remove('show');
  }
  function armSecondStage(){
    stage = 1;
    if (timer) clearTimeout(timer);
    timer = setTimeout(()=>{ stage = 0; timer = null; }, ms);
  }

  hot1.addEventListener('click', (e)=>{
    if (stage !== 0) return;
    armSecondStage();
  });

  hot2.addEventListener('click', (e)=>{
    if (stage !== 1) { reset(); return; }
    stage = 2;
    clearTimeout(timer); timer = null;
    secretBtn.classList.add('show');
    // auto-hide after 12s (optional)
    setTimeout(()=>{ secretBtn.classList.remove('show'); stage = 0; }, 12000);
  });

  // Hide/reset if user clicks elsewhere while armed
  document.addEventListener('click', (e)=>{
    const t = e.target;
    const isHot = t === hot1 || t === hot2 || t === secretBtn;
    if (!isHot && stage === 1) { reset(); }
  }, true);

  // ======= CRYPTO HELPERS (WebCrypto; nothing is stored) =======
  function b64ToBytes(b64){
    const bin = atob(b64);
    const out = new Uint8Array(bin.length);
    for (let i=0; i<bin.length; i++) out[i] = bin.charCodeAt(i);
    return out;
  }
  async function deriveKey(pass, saltBytes){
    const enc = new TextEncoder();
    const keyMaterial = await crypto.subtle.importKey("raw", enc.encode(pass), { name: "PBKDF2" }, false, ["deriveKey"]);
    // Increase iterations if you like (tradeoff: slower unlock)
    return crypto.subtle.deriveKey(
      { name: "PBKDF2", salt: saltBytes, iterations: 200000, hash: "SHA-256" },
      keyMaterial, { name: "AES-GCM", length: 256 }, false, ["decrypt"]
    );
  }
  async function decryptUrlWith(pass){
    // try{
      const salt = b64ToBytes(SALT_B64);
      const iv   = b64ToBytes(IV_B64);
      const ct   = b64ToBytes(CT_B64);
      const key  = await deriveKey(pass, salt);
      const pt   = await crypto.subtle.decrypt({ name: "AES-GCM", iv }, key, ct);
      return new TextDecoder().decode(pt);
    // }catch(e){
    //   return null; // wrong passphrase or tampered blob
    // }
  }
  // =============================================================

  // What the hidden button does now:
  secretBtn.addEventListener('click', async ()=>{
    // Simple UX: native prompt. Replace with your own modal if you have one.
    const pass = window.prompt("Enter passphrase");
    if (!pass) return;

    const url = await decryptUrlWith(pass);
    if (url && /^https?:\/\//i.test(url)){
      // Optional: prevent referrer leakage to Google Docs
      const meta = document.createElement('meta');
      meta.name = 'referrer'; meta.content = 'no-referrer';
      document.head.appendChild(meta);
      location.href = url;   // navigate to the decrypted URL
    } else {
      alert("Incorrect passphrase.");
    }
  });

  // Optional keyboard fallback: press W then H to reveal
  const seq = ['KeyW','KeyH'];
  let idx = 0;
  window.addEventListener('keydown', (e)=>{
    if (e.code === seq[idx]){
      idx++;
      if (idx === seq.length){ secretBtn.classList.add('show'); idx = 0; }
    } else { idx = 0; }
  });
})();
</script>

</BaseLayout>
