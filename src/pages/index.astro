                <!-- Slide surface keeps layout stable -->
                <div id="heroSlides" class="relative aspect-[4/3] bg-slate-200 overflow-hidden"></div>

                <!-- <!-1- Prev / Next -1-> -->
                <!-- <button id="heroPrev" -->
                <!--         class="group absolute left-3 top-1/2 -translate-y-1/2 rounded-full bg-white/80 hover:bg-white p-2 shadow ring-1 ring-slate-300"> -->
                <!--     <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-active:-translate-x-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.78 15.22a.75.75 0 01-1.06 0l-4.5-4.5a.75.75 0 010-1.06l4.5-4.5a.75.75 0 111.06 1.06L8.56 10l4.22 4.22a.75.75 0 010 1.06z" clip-rule="evenodd"/></svg> -->
                <!--     <span class="sr-only">Previous</span> -->
                <!-- </button> -->
                <!-- <button id="heroNext" -->
                <!--         class="group absolute right-3 top-1/2 -translate-y-1/2 rounded-full bg-white/80 hover:bg-white p-2 shadow ring-1 ring-slate-300"> -->
                <!--     <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-active:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.22 4.78a.75.75 0 011.06 0l4.5 4.5a.75.75 0 010 1.06l-4.5 4.5a.75.75 0 11-1.06-1.06L11.44 10 7.22 5.78a.75.75 0 010-1.06z" clip-rule="evenodd"/></svg> -->
                <!--     <span class="sr-only">Next</span> -->
                <!-- </button> -->
                <!-- Prev -->
                <button id="heroPrev"
                        class="group absolute left-2 top-1/2 -translate-y-1/2 p-1">
