import LabNews from '../components/LabNews.astro';
import Research from '../components/Research.astro';
import Talks from '../components/Talks.astro';
import Publications from '../components/Publications.astro';
import Media from '../components/Media.astro';
import People from '../components/People.astro';
import Alumni from '../components/Alumni.astro';
import Teaching from '../components/Teaching.astro';
