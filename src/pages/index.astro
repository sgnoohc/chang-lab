          </div>
          <p class="mt-6 text-white/90 text-sm">Affiliation • Department of Physics • University of Florida</p>
        </div>
        <div class="lg:col-span-5">
          <div class="rounded-3xl overflow-hidden shadow-2xl border border-white/40">
            <!-- <img src="EventDisplay5lepLabel.png" alt="WZZ event display" class="w-full h-[320px] object-cover"/> -->
            <!-- <img src="https://news.fnal.gov/wp-content/uploads/2020/06/cms-detector-0808022_01-A4-at-144-dpi.jpg" alt="The CMS detector at the CERN Large Hadron Collider" class="w-full h-[380px] object-cover" /> -->
            <!-- RIGHT SIDE: Hero carousel -->
            <!-- <div id="hero-carousel" class="relative w-full max-w-2xl rounded-3xl overflow-hidden shadow-xl"> -->
