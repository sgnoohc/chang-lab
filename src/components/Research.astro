---
import { research } from '../data/research';
---

<!-- Research (3-column carousel) -->
<section id="research" class="scroll-mt-28 py-16" aria-labelledby="research-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 overflow-hidden" style="contain:paint">
        <div class="flex items-center justify-between mb-4">
            <h2 id="research-heading" class="text-2xl font-bold">Research</h2>
            <div class="space-x-2">
                <button id="research-prev" aria-label="Previous research topics" aria-controls="research-container" class="px-3 py-1 rounded-full border border-slate-300 bg-white shadow-sm hover:bg-slate-100">←</button>
                <button id="research-next" aria-label="Next research topics" aria-controls="research-container" class="px-3 py-1 rounded-full border border-slate-300 bg-white shadow-sm hover:bg-slate-100">→</button>
            </div>
        </div>

        <div id="research-container" role="region" aria-label="Research topics carousel" class="flex flex-nowrap gap-6 overflow-x-auto scroll-smooth no-scrollbar">

            {research.map((item, i) => (
                <article class={`card rounded-2xl border border-slate-200 bg-white p-6 w-[85vw] sm:w-[45vw] lg:w-[30vw] max-w-[420px] flex-shrink-0${i === 0 ? ' overflow-x-clip [contain:inline-size]' : ''}`}>
                    <h3 class="font-semibold">{item.title}</h3>
                    <img class="mt-4 rounded-xl max-w-full"
                         src={item.primaryImage}
                         alt={item.primaryImageAlt} />
                    {/* MOBILE: toggle control */}
                    <div class={`mt-3 md:hidden min-w-0${i === 0 ? ' max-w-full overflow-x-clip [contain:inline-size] [content-visibility:auto]' : ' max-w-full overflow-x-clip [contain:inline-size] [content-visibility:auto]'}`}>
                        <button type="button"
                                class="research-read-more inline-flex items-center gap-1 text-sm font-medium text-blue-600 cursor-pointer select-none"
                                aria-expanded="false"
                                aria-controls={`research-content-${i}`}>
                            <span class="read-more-text">Read more ↓</span>
                        </button>
                        <div id={`research-content-${i}`} class="hidden mt-2">
                            <p class="text-sm text-slate-600" set:html={item.description} />
                            {item.secondaryImage && (
                                <img class="mt-4 rounded-xl max-w-full"
                                     src={item.secondaryImage}
                                     alt={item.secondaryImageAlt || ""} />
                            )}
                            {item.links.length === 1 ? (
                                <a href={item.links[0].url}
                                   target={item.links[0].external ? "_blank" : undefined}
                                   rel={item.links[0].external ? "noopener" : undefined}
                                   class="mt-3 inline-block text-blue-600 hover:underline">
                                    {item.links[0].text}
                                </a>
                            ) : (
                                <div class="mt-4 space-y-1 text-sm">
                                    {item.links.map((link) => (
                                        <a href={link.url}
                                           target={link.external ? "_blank" : undefined}
                                           rel={link.external ? "noopener noreferrer" : undefined}
                                           class="text-[var(--brand)] font-medium block">
                                            {link.text}
                                        </a>
                                    ))}
                                </div>
                            )}
                        </div>
                    </div>
                    {/* DESKTOP/TABLET: always-visible content */}
                    <div class="hidden md:block mt-3 min-w-0">
                        <p class="text-sm text-slate-600" set:html={item.description} />
                        {item.secondaryImage && (
                            <img class="mt-4 rounded-xl"
                                 src={item.secondaryImage}
                                 alt={item.secondaryImageAlt || ""} />
                        )}
                        {item.links.length === 1 ? (
                            <a href={item.links[0].url}
                               target={item.links[0].external ? "_blank" : undefined}
                               rel={item.links[0].external ? "noopener" : undefined}
                               class="mt-3 inline-block text-blue-600 hover:underline">
                                {item.links[0].text}
                            </a>
                        ) : (
                            <div class="mt-4 space-y-1 text-sm">
                                {item.links.map((link) => (
                                    <a href={link.url}
                                       target={link.external ? "_blank" : undefined}
                                       class="text-[var(--brand)] font-medium block">
                                        {link.text}
                                    </a>
                                ))}
                            </div>
                        )}
                    </div>
                </article>
            ))}

        </div>
    </div>
</section>

<script is:inline>
    (function () {
        const container = document.getElementById('research-container');
        const prev = document.getElementById('research-prev');
        const next = document.getElementById('research-next');

        const CARD_STRIDE = container.clientWidth;

        prev.addEventListener('click', () => {
            container.scrollBy({ left: -CARD_STRIDE, behavior: 'smooth' });
        });
        next.addEventListener('click', () => {
            container.scrollBy({ left:  CARD_STRIDE, behavior: 'smooth' });
        });
    })();
</script>

<script is:inline>
  (function () {
    let t;
    function syncResearchCards() {
      const openOnWide = window.innerWidth >= 1024;
      document.querySelectorAll('#research details.research-autoopen').forEach(d => {
        if (openOnWide) d.setAttribute('open', '');
        else d.removeAttribute('open');
      });
    }
    window.addEventListener('load', syncResearchCards);
    window.addEventListener('resize', () => {
      clearTimeout(t);
      t = setTimeout(syncResearchCards, 150);
    });
  })();
</script>

<script is:inline>
  // Research "Read more" toggle buttons
  document.querySelectorAll('.research-read-more').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const targetId = btn.getAttribute('aria-controls');
      const content = document.getElementById(targetId);
      if (expanded) {
        content.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        btn.querySelector('.read-more-text').textContent = 'Read more ↓';
      } else {
        content.classList.remove('hidden');
        btn.setAttribute('aria-expanded', 'true');
        btn.querySelector('.read-more-text').textContent = 'Show less ↑';
      }
    });
  });
</script>

<style>
/* Hide scrollbar but keep scroll functionality */
.no-scrollbar::-webkit-scrollbar { display: none; }
.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
