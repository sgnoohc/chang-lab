---
import { courses } from '../data/teaching';
---

<!-- Teaching -->
<section id="teaching" class="scroll-mt-28 py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-bold">Teaching</h2>
    <div class="mt-6 grid md:grid-cols-4 gap-6">

      {courses.map((course) => (
        <div class="card rounded-2xl border border-slate-200 bg-white p-6">
          <div class="text-sm text-slate-500">{course.semester}</div>
          <div class="mt-1 font-semibold">{course.title}</div>
          {course.gatorEval && (
            <p class="mt-2 text-sm text-slate-500">GatorEval {course.gatorEval}</p>
          )}
          {course.note && (
            <p class="mt-2 text-sm text-slate-600">{course.note}</p>
          )}
          <p class="mt-2 text-sm text-slate-700">
            <a class="text-[var(--brand)]" href={course.canvasUrl}>Canvas (UF Internal)</a>
          </p>
        </div>
      ))}

    </div>
  </div>
</section>
