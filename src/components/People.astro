---
import { people } from '../data/people';
---

<!-- People -->
<section id="people" class="scroll-mt-28 py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-bold">People</h2>
    <div class="mt-8 grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

      {people.map((person) => (
        <div class="card rounded-2xl border border-slate-200 bg-white p-5">
          <img class="w-52 h-52 object-cover rounded-full mx-auto" src={person.image} alt={`${person.name} portrait`} />
          <div class="mt-4">
            <div class="font-semibold">{person.name}</div>
            <div class="text-sm text-slate-600">{person.role}</div>
            {person.links && person.links.length > 0 && (
              <div class="mt-2 text-sm">
                {person.links.map((link, i) => (
                  <><a class="text-[var(--brand)]" href={link.url}>{link.text}</a>{i < person.links!.length - 1 && ' · '}</>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}

    </div>
  </div>
</section>
