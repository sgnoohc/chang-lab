---
import { labNews } from '../data/labNews';
---

<!-- Lab News -->
<section id="lab-news" class="scroll-mt-28 py-16 bg-slate-50" aria-labelledby="lab-news-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="flex items-center justify-between mb-4">
      <h2 id="lab-news-heading" class="text-2xl font-bold">Lab News</h2>
      <div class="space-x-2">
        <button id="labnews-prev"
                aria-label="Previous news items"
                aria-controls="labnews-container"
                class="px-3 py-1 rounded-full border border-slate-300 bg-white shadow-sm hover:bg-slate-100">
          ←
        </button>
        <button id="labnews-next"
                aria-label="Next news items"
                aria-controls="labnews-container"
                class="px-3 py-1 rounded-full border border-slate-300 bg-white shadow-sm hover:bg-slate-100">
          →
        </button>
      </div>
    </div>

    <!-- Scroll container -->
    <div id="labnews-container"
         role="region" aria-label="Lab news carousel"
         class="grid grid-flow-col auto-cols-[minmax(260px,1fr)] lg:auto-cols-[minmax(320px,1fr)]
                gap-6 overflow-x-auto scroll-smooth no-scrollbar">

      {labNews.map((item) => (
        <article class="card rounded-2xl border border-slate-200 bg-white p-5 flex flex-col h-[420px]">
          <div class="text-xs text-slate-500 uppercase tracking-wide">{item.date}</div>
          <p class="mt-2 text-sm leading-relaxed">
            <span class="font-bold">{item.name}</span> <span set:html={item.text} />
          </p>
          <div class="mt-4 relative flex-1 overflow-hidden rounded-xl">
            <img src={item.image}
                 class="absolute inset-0 w-full h-full object-cover"
                 alt={item.imageAlt} />
          </div>
        </article>
      ))}

    </div>
  </div>
</section>

<script is:inline>
    (function () {
        const container = document.getElementById('labnews-container');
        const prev = document.getElementById('labnews-prev');
        const next = document.getElementById('labnews-next');

        const CARD_STRIDE = container.clientWidth;

        prev.addEventListener('click', () => {
            container.scrollBy({ left: -CARD_STRIDE, behavior: 'smooth' });
        });
        next.addEventListener('click', () => {
            container.scrollBy({ left:  CARD_STRIDE, behavior: 'smooth' });
        });
    })();
</script>
